    "url": "https://github.com/foobert/p.funkenburg.net/issues"
  },
  "homepage": "https://github.com/foobert/p.funkenburg.net#readme",
  "devDependencies": {
    "aws-sdk": "^2.205.0",
    "babel-cli": "^6.26.0",
    "babel-core": "^6.26.0",
    "babel-preset-env": "^1.6.1",
    "babel-preset-es2017": "^6.24.1",
    "prettier": "1.10.2",
    "s3rver": "^2.2.0"
  },
  "dependencies": {
    "chokidar": "^2.0.3",
    "debug": "^3.1.0",
    "gm": "^1.23.1",
    "js-yaml": "^3.10.0",
    "mkdirp-promise": "^5.0.1",
